<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Push notifications. iOS + Catalyst, no provisioning profile
	     changes required vs the original APNs-only setup. -->
	<key>aps-environment</key>
	<string>production</string>
	<key>com.apple.developer.aps-environment</key>
	<string>production</string>

	<!--
	  Mac Catalyst note:
	  ENABLE_APP_SANDBOX is set to NO on the target so the build
	  works with the existing Apple ID + automatic signing without
	  needing the Apple Developer portal to add Network / Camera /
	  Photos / Location capabilities to the App ID. Sign-in (and
	  every other HTTPS call) works because nothing is blocking
	  outbound network traffic.

	  Re-enabling App Sandbox is a Mac App Store distribution task —
	  not required for development, TestFlight, or Developer ID
	  Direct distribution. When that time comes, flip
	  ENABLE_APP_SANDBOX back to YES and add these entitlements:

	    <key>com.apple.security.network.client</key>            <true/>
	    <key>com.apple.security.files.user-selected.read-write</key> <true/>
	    <key>com.apple.security.device.camera</key>             <true/>
	    <key>com.apple.security.personal-information.photos-library</key> <true/>
	    <key>com.apple.security.personal-information.location</key> <true/>

	  …then click "Try Again" in Xcode's Signing & Capabilities tab
	  to regenerate the provisioning profile.
	-->
</dict>
</plist>
